# ---------------------------------------------------------------------------
# Required in every environment
# ---------------------------------------------------------------------------
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://auction:auction@localhost:5433/auction_dev?schema=public
NEXTAUTH_SECRET=your-long-random-nextauth-secret
INTERNAL_JOB_SECRET=your-long-random-internal-job-secret
TERMS_VERSION=v1

# ---------------------------------------------------------------------------
# Optional auth tuning
# ---------------------------------------------------------------------------
AUTH_SESSION_COOKIE_NAME=layu_session
AUTH_COOKIE_DOMAIN=
AUTH_SESSION_TTL_HOURS=720
AUTH_EMAIL_VERIFICATION_TTL_HOURS=24
AUTH_PASSWORD_RESET_TTL_HOURS=2

# ---------------------------------------------------------------------------
# Persona verification
# Optional until the Persona flow is enabled, but PERSONA_WEBHOOK_SECRET should
# be set anywhere Persona webhooks are expected to hit the app.
# PERSONA_API_KEY is reserved for future server-to-server Persona API calls.
# Current app code does not read it and it is not required for hosted-flow
# redirects or signed webhook verification.
# ---------------------------------------------------------------------------
PERSONA_API_KEY=persona_api_key_here
PERSONA_TEMPLATE_ID=persona_template_id_here
PERSONA_ENVIRONMENT_ID=persona_environment_id_here
PERSONA_SUBDOMAIN=inquiry
PERSONA_WEBHOOK_SECRET=persona_webhook_secret_here

# ---------------------------------------------------------------------------
# Email delivery
# Use EMAIL_DRIVER=console for local development.
# Use EMAIL_DRIVER=webhook in production and point EMAIL_WEBHOOK_URL at your
# mail bridge, worker, or provider-facing delivery endpoint.
# SMTP placeholders remain here for future direct SMTP work or an external relay.
# ---------------------------------------------------------------------------
EMAIL_DRIVER=console
EMAIL_FROM=auctions@example.com
EMAIL_REPLY_TO=support@example.com
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_BEARER_TOKEN=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=auctions@example.com

# ---------------------------------------------------------------------------
# Storage
# Use STORAGE_DRIVER=local for development.
# Use STORAGE_DRIVER=object for production object storage.
# If you keep STORAGE_DRIVER=local in staging/production, set BOTH
# LOCAL_UPLOAD_DIR and LOCAL_PUBLIC_UPLOAD_BASE_URL explicitly and back the
# upload directory with persistent storage.
# If you use STORAGE_DRIVER=object in staging/production,
# OBJECT_STORAGE_PUBLIC_BASE_URL should be set to the public bucket/CDN URL.
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./.local/uploads
LOCAL_PUBLIC_UPLOAD_BASE_URL=http://localhost:3000/uploads
OBJECT_STORAGE_BUCKET=auction-assets
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_ENDPOINT=https://object-storage.example.com
OBJECT_STORAGE_ACCESS_KEY_ID=object_storage_access_key_here
OBJECT_STORAGE_SECRET_ACCESS_KEY=object_storage_secret_here
OBJECT_STORAGE_PUBLIC_BASE_URL=https://cdn.example.com/auction-assets
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# ---------------------------------------------------------------------------
# External payment handles / links
# ---------------------------------------------------------------------------
PAYPAL_ME_URL=https://paypal.me/your-handle
VENMO_HANDLE=@yourvenmo
VENMO_PROFILE_URL=https://venmo.com/yourvenmo
CASH_APP_CASHTAG=$$yourcashtag
CASH_APP_PROFILE_URL=https://cash.app/$$yourcashtag

# ---------------------------------------------------------------------------
# Local development fixture seed
# Leave SEED_LOCAL_DEV_DATA=false outside local development.
# When enabled, prisma/seed.ts creates a usable admin, a normal user, and
# several published sample listings.
# ---------------------------------------------------------------------------
SEED_LOCAL_DEV_DATA=false
DEV_SEED_ADMIN_EMAIL=admin@local.layu.test
DEV_SEED_ADMIN_PASSWORD=DevAdmin123!
DEV_SEED_USER_EMAIL=bidder@local.layu.test
DEV_SEED_USER_PASSWORD=DevBuyer123!
